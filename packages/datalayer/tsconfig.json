{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "allowJs": true,
    "target": "ES2020",
    "module": "ESNext", // 使用 ESM 模块
    "moduleResolution": "bundler", // 或 "node"
    "lib": ["ES2020"],
    "declaration": true, // 生成 .d.ts 类型声明
    "declarationMap": true, // 生成类型映射（便于调试）
    "sourceMap": true,
    "outDir": "./dist", // 输出目录
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
